# === CLOUDFLARE ===
CLOUDFLARE_DATABASE_NAME="clover-db"

# === JWT (replaces NextAuth) ===
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET="your-random-secret-here"

# === AI CHATBOT (Gemini + Groq auto-fallback) ===
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
# Groq: https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# === WHATSAPP ===
# Nomor WhatsApp tanpa + (contoh: 6281234567890)
NEXT_PUBLIC_WA_NUMBER="6281234567890"

# === CLOUDFLARE TURNSTILE (anti-bot login, gratis) ===
# Daftar widget di https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# === NEXT ===
NEXT_PUBLIC_URL="https://arazhar.dev"
